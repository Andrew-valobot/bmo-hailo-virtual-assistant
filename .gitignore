# --- Python Artifacts ---
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/

# --- Virtual Environments ---
venv/
env/
bmo_env/
.conda/

# --- Environment Variables & Secrets ---
.env
config.json

# --- Large Models & Binaries (AI Hardware) ---
# Ignore Piper TTS folder (OS-specific and heavy)
piper/

# Ignore local AI model weights
*.onnx
*.bin
*.tflite
*.hef
*.gguf

# Exception: Un-comment the line below if you WANT to share your custom wake word
# !wakeword.onnx

# --- User Configuration & Memory ---
# Keep chat history local for privacy
memory.json
chat_memory.json

# --- Temporary/Generated Media ---
*.wav
*.mp3
*.jpg
*.jpeg
*.png
camera_capture.jpg
current_image.jpg
test_audio.wav

# --- OS Generated Files ---
.DS_Store
Thumbs.db
ehthumbs.db

# --- Installers & Packages ---
*.deb
*.whl

# Exception: Allow specific installers in the vault folder
!vault/installers/*.whl
!vault/installers/*.deb
